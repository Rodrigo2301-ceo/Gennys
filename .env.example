# Anthropic
ANTHROPIC_API_KEY=<anthropic-api-key>

# Gemini (Google AI Studio — camada gratuita)
GEMINI_API_KEY=<gemini-api-key>
# GEMINI_MODEL=gemini-2.0-flash

# Groq (console.groq.com — free tier, roda Llama)
GROQ_API_KEY=<groq-api-key>
# GROQ_MODEL=llama-3.3-70b-versatile

# PostgreSQL (Railway: Settings > Database > Connection String)
DATABASE_URL=postgresql://user:password@host:5432/gennys

# NextAuth
NEXTAUTH_SECRET=<random-secret-with-at-least-32-bytes>
NEXTAUTH_URL=http://localhost:3000

# HMAC de rate limits e confirmacoes. Gere um valor diferente de NEXTAUTH_SECRET.
SECURITY_HMAC_SECRET=<independent-random-secret-with-at-least-32-bytes>
